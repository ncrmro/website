---
import { env } from 'cloudflare:workers';
import AdminPostForm from '../../../components/AdminPostForm.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { ALLOWED_EMAIL, getSession, type AuthEnv } from '../../../lib/auth';

export const prerender = false;

const session = await getSession(Astro.request, env as AuthEnv);

if (session?.user?.email?.toLowerCase() !== ALLOWED_EMAIL) {
	return Astro.redirect(`/api/auth/signin?callbackUrl=${encodeURIComponent('/admin/posts/new')}`);
}
---

<BaseLayout title="New post" description="Create a blog post change through a GitHub PR preview.">
	<section class="w-full max-w-6xl space-y-6 py-8">
		<div class="space-y-2">
			<p class="text-sm uppercase tracking-wide text-gray-500 dark:text-gray-400">Admin</p>
			<h1 class="text-4xl font-bold">New post</h1>
			<p class="max-w-2xl text-gray-700 dark:text-gray-300">Create a draft post branch and pull request.</p>
		</div>
		<AdminPostForm mode="new" />
	</section>
</BaseLayout>
