---
import { getCollection } from 'astro:content';
import { env } from 'cloudflare:workers';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { ALLOWED_EMAIL, getSession, type AuthEnv } from '../../../lib/auth';

export const prerender = false;

const session = await getSession(Astro.request, env as AuthEnv);

if (session?.user?.email?.toLowerCase() !== ALLOWED_EMAIL) {
	return Astro.redirect(`/api/auth/signin?callbackUrl=${encodeURIComponent('/admin/posts')}`);
}

const posts = (await getCollection('blog')).sort((a, b) => {
	const aDate = a.data.publish_date?.getTime() ?? 0;
	const bDate = b.data.publish_date?.getTime() ?? 0;
	return bDate - aDate;
});
---

<BaseLayout title="Manage posts" description="Create and edit blog post changes through GitHub PR previews.">
	<section class="w-full max-w-5xl space-y-6 py-8">
		<div class="flex flex-wrap items-start justify-between gap-4">
			<div class="space-y-2">
				<p class="text-sm uppercase tracking-wide text-gray-500 dark:text-gray-400">Admin</p>
				<h1 class="text-4xl font-bold">Posts</h1>
				<p class="max-w-2xl text-gray-700 dark:text-gray-300">
					Choose a post to edit or create a new draft. Editing opens a dedicated form page and commits changes through a GitHub PR.
				</p>
			</div>
			<a class="rounded-md bg-gray-950 px-4 py-2 font-semibold text-white hover:bg-gray-800 dark:bg-white dark:text-gray-950 dark:hover:bg-gray-200" href="/admin/posts/new">
				New post
			</a>
		</div>

		<div class="flex flex-wrap items-center justify-between gap-3 rounded-xl border border-emerald-300 bg-emerald-50 p-4 text-sm text-emerald-950 dark:border-emerald-700 dark:bg-emerald-950 dark:text-emerald-100">
			<span>Signed in as <strong>{session.user?.email}</strong>.</span>
			<a class="underline" href={`/api/auth/signout?callbackUrl=${encodeURIComponent('/')}`}>Sign out</a>
		</div>

		<div class="space-y-3">
			{posts.map((post) => (
				<a class="block rounded-xl border border-gray-200 p-4 hover:bg-gray-50 dark:border-gray-700 dark:hover:bg-gray-800" href={`/admin/posts/${encodeURIComponent(post.id)}`}>
					<div class="flex flex-wrap items-start justify-between gap-3">
						<div>
							<h2 class="font-semibold text-gray-950 dark:text-white">{post.data.title}</h2>
							<p class="text-sm text-gray-600 dark:text-gray-300">{post.data.description}</p>
						</div>
						<span class="rounded-full border border-gray-200 px-2 py-1 text-xs text-gray-500 dark:border-gray-700 dark:text-gray-400">
							{post.data.published ? 'published' : 'draft'}
						</span>
					</div>
					<p class="mt-2 font-mono text-xs text-gray-500 dark:text-gray-400">{post.id}</p>
				</a>
			))}
		</div>
	</section>
</BaseLayout>
