{
  "name": "ncrmro-website",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@8.6.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev --turbopack -p ${WEB_PORT:-3000}",
    "build": "next build",
    "start": "next start -p ${WEB_PORT:-3000}",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "e2e": "playwright test",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv"
  },
  "dependencies": {
    "@tailwindcss/forms": "^0.5.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "10.4.14",
    "next": "15.4.8",
    "next-mdx-remote": "^5.0.0",
    "next-pwa": "^5.6.0",
    "postcss": "8.4.22",
    "posthog-js": "^1.257.1",
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "3.3.1",
    "typescript": "^5.1.3",
    "yaml": "^1.10.2"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.3.0",
    "@playwright/test": "^1.35.1",
    "eslint": "8.49.0",
    "eslint-config-next": "13.5.2",
    "prettier": "^2.4.1",
    "wrangler": "^4.25.1"
  },
  "prettier": {
    "proseWrap": "always"
  }
}
