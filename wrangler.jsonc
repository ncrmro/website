{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "ncrmro-website",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"compatibility_date": "2026-05-13",
	"compatibility_flags": [
		"global_fetch_strictly_public"
	],
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	}
}
